{
  "name": "@caresync/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file .env src/db/seed.ts",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@caresync/shared": "workspace:*",
    "@hono/node-server": "^1.13",
    "@hono/zod-openapi": "^0.18",
    "@scalar/hono-api-reference": "^0.5",
    "bcryptjs": "^2.4",
    "drizzle-orm": "^0.38",
    "hono": "^4.7",
    "jsonwebtoken": "^9.0",
    "pg": "^8.13",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4",
    "@types/jsonwebtoken": "^9.0",
    "@types/node": "^22",
    "@types/pg": "^8.11",
    "drizzle-kit": "^0.30",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.19",
    "typescript": "^5.7",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
