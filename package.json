{
  "name": "caresync",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @caresync/e2e test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.6.4",
  "pnpm": {
